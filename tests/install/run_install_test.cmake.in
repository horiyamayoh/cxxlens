set(test_root "@CMAKE_CURRENT_BINARY_DIR@/install-consumer")
set(install_prefix "${test_root}/relocated-prefix")
set(install_libdir "@CMAKE_INSTALL_LIBDIR@")
set(artifact_manifest "${test_root}/install-artifact-manifest.json")
set(artifact_configuration
    "shared=@CXXLENS_BUILD_SHARED@,build_type=@CMAKE_BUILD_TYPE@,asan=@CXXLENS_ENABLE_ASAN@,ubsan=@CXXLENS_ENABLE_UBSAN@,tsan=@CXXLENS_ENABLE_TSAN@"
)

if(NOT DEFINED PHASE)
  message(FATAL_ERROR "install test requires an explicit PHASE")
endif()

function(run_clean expected_result)
  execute_process(
    COMMAND "@CMAKE_COMMAND@" -E env --unset=LD_LIBRARY_PATH
            --unset=DYLD_LIBRARY_PATH ${ARGN}
    RESULT_VARIABLE actual_result
    OUTPUT_VARIABLE command_output
    ERROR_VARIABLE command_error)
  if(NOT actual_result EQUAL expected_result)
    message(
      FATAL_ERROR
        "installed command failed (${actual_result}, expected ${expected_result}): ${ARGN}\nstdout: ${command_output}\nstderr: ${command_error}"
    )
  endif()
endfunction()

function(run_installed_tools label)
  run_clean(0 "${install_prefix}/bin/cxxlens-sdk-doctor" inspect)
  run_clean(1 "${install_prefix}/bin/cxxlens-clang-worker-22")
  set(scaffold_output "${test_root}/scaffold-${label}")
  file(REMOVE_RECURSE "${scaffold_output}")
  run_clean(0 "${install_prefix}/bin/cxxlens-provider-scaffold"
            "${scaffold_output}" company.install.provider portable
            company.install.relation)
endfunction()

if(PHASE STREQUAL "prepare")
  file(REMOVE_RECURSE "${test_root}")
  set(staging_prefix "${test_root}/prefix")
  set(install_prefix "${staging_prefix}")
  execute_process(
    COMMAND "@CMAKE_COMMAND@" --install "@CMAKE_BINARY_DIR@" --prefix
            "${install_prefix}" COMMAND_ERROR_IS_FATAL ANY)

  foreach(
    required IN
    ITEMS
      "${install_prefix}/include/cxxlens/cxxlens.hpp"
      "${install_prefix}/include/cxxlens/sdk.hpp"
      "${install_prefix}/include/cxxlens/sdk/query.hpp"
      "${install_prefix}/include/cxxlens/provider/clang22.hpp"
      "${install_prefix}/include/cxxlens/relations/cc_call_site.hpp"
      "${install_prefix}/${install_libdir}/cmake/cxxlens/cxxlensConfig.cmake"
      "${install_prefix}/${install_libdir}/cmake/cxxlensProviderSDK/cxxlensProviderSDKConfig.cmake"
      "${install_prefix}/${install_libdir}/cmake/cxxlensClang22ProviderSDK/cxxlensClang22ProviderSDKConfig.cmake"
      "${install_prefix}/share/cxxlens/schemas/cxxlens_ng_public_api_catalog.yaml"
      "${install_prefix}/share/cxxlens/schemas/cxxlens_ng_clang22_materialization_contract.yaml"
      "${install_prefix}/share/cxxlens/schemas/cxxlens_ng_clang22_materialization_contract.schema.yaml"
      "${install_prefix}/share/cxxlens/schemas/cxxlens_ng_clang22_materialization_request.schema.yaml"
      "${install_prefix}/share/cxxlens/schemas/cxxlens_ng_clang22_materialization_report.schema.yaml"
      "${install_prefix}/share/doc/cxxlens/LICENSE"
      "${install_prefix}/share/doc/cxxlens/NOTICE"
      "${install_prefix}/bin/cxxlens-provider-scaffold"
      "${install_prefix}/bin/cxxlens-sdk-doctor"
      "${install_prefix}/bin/cxxlens-clang-worker-22")
    if(NOT EXISTS "${required}")
      message(
        FATAL_ERROR "installed next-generation artifact is missing: ${required}"
      )
    endif()
  endforeach()

  run_installed_tools(original)

  return()
endif()

if(PHASE STREQUAL "relocation")
  file(RENAME "${test_root}/prefix" "${install_prefix}")
  run_installed_tools(relocated)
  execute_process(
    COMMAND
      "@Python3_EXECUTABLE@"
      "@CMAKE_CURRENT_SOURCE_DIR@/../tools/quality/install_artifact_manifest.py"
      create --root "@CMAKE_CURRENT_SOURCE_DIR@/.." --prefix
      "${install_prefix}" --compiler "@CMAKE_CXX_COMPILER@" --configuration
      "${artifact_configuration}" --manifest "${artifact_manifest}"
      COMMAND_ERROR_IS_FATAL ANY)
  return()
endif()

execute_process(
  COMMAND
    "@Python3_EXECUTABLE@"
    "@CMAKE_CURRENT_SOURCE_DIR@/../tools/quality/install_artifact_manifest.py"
    verify --root "@CMAKE_CURRENT_SOURCE_DIR@/.." --prefix "${install_prefix}"
    --compiler "@CMAKE_CXX_COMPILER@" --configuration
    "${artifact_configuration}" --manifest "${artifact_manifest}"
    COMMAND_ERROR_IS_FATAL ANY)

if(PHASE STREQUAL "shared-runtime-layout")
  if(NOT "@CXXLENS_BUILD_SHARED@" STREQUAL "ON")
    return()
  endif()
  set(layout_prefix "${test_root}/layout-prefix")
  file(REMOVE_RECURSE "${layout_prefix}")
  file(COPY "${install_prefix}/" DESTINATION "${layout_prefix}")
  set(install_prefix "${layout_prefix}")
endif()

if(PHASE STREQUAL "shared-runtime-layout"
   AND UNIX
   AND NOT APPLE)
  find_program(CXXLENS_READELF NAMES readelf llvm-readelf REQUIRED)
  foreach(tool IN ITEMS cxxlens-provider-scaffold cxxlens-sdk-doctor
                        cxxlens-clang-worker-22)
    execute_process(
      COMMAND "${CXXLENS_READELF}" -d "${install_prefix}/bin/${tool}"
      OUTPUT_VARIABLE dynamic_section COMMAND_ERROR_IS_FATAL ANY)
    if(NOT dynamic_section MATCHES "RUNPATH.*\\$ORIGIN/../${install_libdir}")
      message(FATAL_ERROR "installed tool lacks relocatable RUNPATH: ${tool}")
    endif()
    if(dynamic_section MATCHES "@CMAKE_BINARY_DIR@")
      message(FATAL_ERROR "installed tool retains build-tree path: ${tool}")
    endif()
  endforeach()
  file(GLOB base_libraries
       "${install_prefix}/${install_libdir}/libcxxlens_base.so.*")
  if(NOT base_libraries)
    message(FATAL_ERROR "shared package lacks versioned cxxlens base library")
  endif()
  list(GET base_libraries 0 base_library)
  execute_process(
    COMMAND "${CXXLENS_READELF}" -d "${base_library}"
    OUTPUT_VARIABLE library_dynamic_section COMMAND_ERROR_IS_FATAL ANY)
  if(NOT library_dynamic_section MATCHES "SONAME.*libcxxlens_base.so.1")
    message(FATAL_ERROR "shared library SONAME does not bind project major")
  endif()
  if(NOT library_dynamic_section MATCHES "RUNPATH.*\\$ORIGIN")
    message(
      FATAL_ERROR "shared library lacks same-directory relocatable RUNPATH")
  endif()
  if(library_dynamic_section MATCHES "@CMAKE_BINARY_DIR@")
    message(FATAL_ERROR "installed library retains build-tree path")
  endif()

  set(base_soname "${install_prefix}/${install_libdir}/libcxxlens_base.so.1")
  set(base_soname_unavailable "${base_soname}.unavailable")
  if(NOT EXISTS "${base_soname}")
    message(FATAL_ERROR "shared package lacks the cxxlens base SONAME link")
  endif()
  file(RENAME "${base_soname}" "${base_soname_unavailable}")
  execute_process(
    COMMAND
      "@CMAKE_COMMAND@" -E env --unset=LD_LIBRARY_PATH --unset=DYLD_LIBRARY_PATH
      "${install_prefix}/bin/cxxlens-sdk-doctor" inspect
    RESULT_VARIABLE missing_dependency_result
    OUTPUT_VARIABLE missing_dependency_output
    ERROR_VARIABLE missing_dependency_error)
  file(RENAME "${base_soname_unavailable}" "${base_soname}")
  if(missing_dependency_result EQUAL 0)
    message(FATAL_ERROR "installed tool ignored a missing shared dependency")
  endif()
  if(NOT missing_dependency_error MATCHES "libcxxlens_base\\.so\\.1")
    message(
      FATAL_ERROR
        "missing shared dependency diagnostic lacks the SONAME: ${missing_dependency_error}"
    )
  endif()
endif()

if(PHASE STREQUAL "shared-runtime-layout")
  return()
endif()

if(PHASE STREQUAL "legacy-zero")
  foreach(
    forbidden IN
    ITEMS
      "${install_prefix}/include/cxxlens/facts.hpp"
      "${install_prefix}/include/cxxlens/select.hpp"
      "${install_prefix}/include/cxxlens/workspace.hpp"
      "${install_prefix}/include/cxxlens/interop/clang.hpp"
      "${install_prefix}/bin/cxxlens-frontend-worker"
      "${install_prefix}/share/cxxlens/schemas/cxxlens_public_api_contract.yaml"
      "${install_prefix}/share/cxxlens/schemas/cxxlens_m2_completion.yaml")
    if(EXISTS "${forbidden}")
      message(FATAL_ERROR "legacy artifact was installed: ${forbidden}")
    endif()
  endforeach()
  return()
endif()

if(PHASE STREQUAL "real-project-incompatible-version")
  set(negative_build_dir "${test_root}/real-project-incompatible-build")
  file(REMOVE_RECURSE "${negative_build_dir}")
  execute_process(
    COMMAND
      "@CMAKE_COMMAND@" -S
      "@CMAKE_CURRENT_SOURCE_DIR@/install/real_project_consumer" -B
      "${negative_build_dir}" "-DCMAKE_PREFIX_PATH=${install_prefix}"
      "-DCMAKE_CXX_COMPILER=@CMAKE_CXX_COMPILER@"
      "-DCXXLENS_REQUIRE_INCOMPATIBLE_VERSION=ON"
    RESULT_VARIABLE incompatible_result
    OUTPUT_QUIET ERROR_QUIET)
  if(incompatible_result EQUAL 0)
    message(
      FATAL_ERROR "real project accepted an incompatible distribution major")
  endif()
  return()
endif()

if(PHASE MATCHES "^(core|sdk|clang22-sdk|real-project)-consumer$")
  if(PHASE STREQUAL "core-consumer")
    set(consumer consumer)
  elseif(PHASE STREQUAL "sdk-consumer")
    set(consumer sdk_consumer)
  elseif(PHASE STREQUAL "real-project-consumer")
    set(consumer real_project_consumer)
  else()
    set(consumer clang22_sdk_consumer)
  endif()
  set(build_dir "${test_root}/${consumer}-build")
  file(REMOVE_RECURSE "${build_dir}")
  execute_process(
    COMMAND
      "@CMAKE_COMMAND@" -S "@CMAKE_CURRENT_SOURCE_DIR@/install/${consumer}" -B
      "${build_dir}" "-DCMAKE_PREFIX_PATH=${install_prefix}"
      "-DCMAKE_CXX_COMPILER=@CMAKE_CXX_COMPILER@" "-DLLVM_DIR=@LLVM_DIR@"
      "-DClang_DIR=@Clang_DIR@" "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
      "-DCXXLENS_ENABLE_ASAN=@CXXLENS_ENABLE_ASAN@"
      "-DCXXLENS_ENABLE_UBSAN=@CXXLENS_ENABLE_UBSAN@"
      "-DCXXLENS_ENABLE_TSAN=@CXXLENS_ENABLE_TSAN@" COMMAND_ERROR_IS_FATAL ANY)
  execute_process(COMMAND "@CMAKE_COMMAND@" --build "${build_dir}"
                          COMMAND_ERROR_IS_FATAL ANY)
  string(REPLACE "_" "-" executable_suffix "${consumer}")
  run_clean(0 "${build_dir}/cxxlens-${executable_suffix}")
  set(consumer_prefix "${test_root}/${consumer}-prefix")
  execute_process(COMMAND "@CMAKE_COMMAND@" --install "${build_dir}" --prefix
                          "${consumer_prefix}" COMMAND_ERROR_IS_FATAL ANY)
  run_clean(0 "${consumer_prefix}/bin/cxxlens-${executable_suffix}")
  return()
endif()

if(PHASE STREQUAL "examples-consumer")
  set(example_build_dir "${test_root}/examples-consumer-build")
  file(REMOVE_RECURSE "${example_build_dir}")
  execute_process(
    COMMAND
      "@CMAKE_COMMAND@" -S
      "@CMAKE_CURRENT_SOURCE_DIR@/install/examples_consumer" -B
      "${example_build_dir}" "-DCMAKE_PREFIX_PATH=${install_prefix}"
      "-DCXXLENS_EXAMPLE_ROOT=${install_prefix}/share/doc/cxxlens/examples/sdk"
      "-DCMAKE_CXX_COMPILER=@CMAKE_CXX_COMPILER@" "-DLLVM_DIR=@LLVM_DIR@"
      "-DClang_DIR=@Clang_DIR@" "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
      "-DCXXLENS_ENABLE_ASAN=@CXXLENS_ENABLE_ASAN@"
      "-DCXXLENS_ENABLE_UBSAN=@CXXLENS_ENABLE_UBSAN@"
      "-DCXXLENS_ENABLE_TSAN=@CXXLENS_ENABLE_TSAN@" COMMAND_ERROR_IS_FATAL ANY)
  execute_process(COMMAND "@CMAKE_COMMAND@" --build "${example_build_dir}"
                          COMMAND_ERROR_IS_FATAL ANY)
  set(example_prefix "${test_root}/examples-consumer-prefix")
  execute_process(
    COMMAND "@CMAKE_COMMAND@" --install "${example_build_dir}" --prefix
            "${example_prefix}" COMMAND_ERROR_IS_FATAL ANY)
  foreach(example IN ITEMS recipe typed_query dynamic_query portable_provider
                           clang22-native)
    run_clean(0 "${example_build_dir}/cxxlens-installed-${example}")
    run_clean(0 "${example_prefix}/bin/cxxlens-installed-${example}")
  endforeach()
  return()
endif()

message(FATAL_ERROR "unknown install test PHASE: ${PHASE}")
