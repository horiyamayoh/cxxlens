set(test_root "@CMAKE_CURRENT_BINARY_DIR@/install-consumer")
set(install_prefix "${test_root}/prefix")
set(consumer_build "${test_root}/build")
set(sdk_consumer_build "${test_root}/sdk-build")
set(phase_b_report "${test_root}/phase-b-contract-integration-report.json")

file(REMOVE_RECURSE "${test_root}")

execute_process(
  COMMAND "@CMAKE_COMMAND@" --install "@CMAKE_BINARY_DIR@" --prefix
          "${install_prefix}" RESULT_VARIABLE install_result
                                              COMMAND_ERROR_IS_FATAL ANY)

foreach(
  required IN
  ITEMS
    "${install_prefix}/include/cxxlens/cxxlens.hpp"
    "${install_prefix}/include/cxxlens/explain.hpp"
    "${install_prefix}/include/cxxlens/search.hpp"
    "${install_prefix}/include/cxxlens/testing.hpp"
    "${install_prefix}/include/cxxlens/workspace.hpp"
    "${install_prefix}/include/cxxlens/facts.hpp"
    "${install_prefix}/include/cxxlens/interop/clang.hpp"
    "${install_prefix}/include/cxxlens/sdk.hpp"
    "${install_prefix}/include/cxxlens/sdk/provider.hpp"
    "${install_prefix}/include/cxxlens/provider/clang22.hpp"
    "${install_prefix}/include/cxxlens/relations/cc_call_site.hpp"
    "${install_prefix}/lib/cmake/cxxlensProviderSDK/cxxlensProviderSDKConfig.cmake"
    "${install_prefix}/lib/cmake/cxxlensClang22ProviderSDK/cxxlensClang22ProviderSDKConfig.cmake"
    "${install_prefix}/bin/cxxlens-provider-scaffold"
    "${install_prefix}/bin/cxxlens-sdk-doctor"
    "${install_prefix}/bin/cxxlens-relation-idl"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_public_api_contract.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_ng_public_api_catalog.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_ng_public_api_catalog.schema.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_phase_b_contract_integration.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_phase_b_contract_integration.schema.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens.agent-task-packet-corpus.v1.json"
    "${install_prefix}/share/cxxlens/schemas/cxxlens.agent-task-packet-validation-report.v1.json"
    "${install_prefix}/share/cxxlens/schemas/cxxlens.agent-task-packet-validation-report.v1.schema.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens.agent-task-packet.v1.schema.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens.agent-ownership.v1.json"
    "${install_prefix}/share/cxxlens/schemas/cxxlens.agent-ownership.v1.schema.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens.dependency-request.examples.v1.json"
    "${install_prefix}/share/cxxlens/schemas/cxxlens.dependency-request.v1.schema.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens.api-ready.report.v1.json"
    "${install_prefix}/share/cxxlens/schemas/cxxlens.api-ready.run-manifest.v1.schema.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens.api-ready.v1.schema.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens.readiness.authorization.v1.json"
    "${install_prefix}/share/cxxlens/schemas/cxxlens.readiness.authorization.v1.schema.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_m0_completion.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_m1_completion.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_m1_completion.schema.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_m1_acceptance_report.schema.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_m2_completion.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_m2_completion.schema.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_m2_acceptance_report.schema.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_analysis_scope.schema.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_workspace_context.schema.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_fact.schema.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_frontend_batch.schema.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_observation.schema.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_search_report.schema.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_explanation.schema.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_agent_task_card.schema.yaml"
    "${install_prefix}/share/doc/cxxlens/examples/m2-flagship/main.cpp"
    "${install_prefix}/share/doc/cxxlens/examples/packages/core.cpp"
    "${install_prefix}/share/doc/cxxlens/examples/packages/interop.cpp"
    "${install_prefix}/share/doc/cxxlens/examples/sdk/typed_query.cpp"
    "${install_prefix}/share/doc/cxxlens/README.md"
    "${install_prefix}/share/doc/cxxlens/SECURITY.md")
  if(NOT EXISTS "${required}")
    message(FATAL_ERROR "installed M0 artifact is missing: ${required}")
  endif()
endforeach()

find_program(phase_b_gxx NAMES g++ REQUIRED)
execute_process(
  COMMAND
    "@Python3_EXECUTABLE@"
    "@CMAKE_CURRENT_SOURCE_DIR@/../tools/quality/check_phase_b_contract_integration.py"
    --root "@CMAKE_CURRENT_SOURCE_DIR@/.." --include-dir
    "${install_prefix}/include" --compiler "@CMAKE_CXX_COMPILER@" --compiler
    "${phase_b_gxx}" --report "${phase_b_report}"
  RESULT_VARIABLE phase_b_result COMMAND_ERROR_IS_FATAL ANY)

execute_process(
  COMMAND
    "@CMAKE_COMMAND@" -S "@CMAKE_CURRENT_SOURCE_DIR@/install/consumer" -B
    "${consumer_build}" "-DCMAKE_PREFIX_PATH=${install_prefix}"
    "-DCMAKE_CXX_COMPILER=@CMAKE_CXX_COMPILER@" "-DLLVM_DIR=@LLVM_DIR@"
    "-DClang_DIR=@Clang_DIR@"
  RESULT_VARIABLE configure_result COMMAND_ERROR_IS_FATAL ANY)

execute_process(COMMAND "@CMAKE_COMMAND@" --build "${consumer_build}"
                RESULT_VARIABLE build_result COMMAND_ERROR_IS_FATAL ANY)

execute_process(COMMAND "${consumer_build}/cxxlens-consumer"
                RESULT_VARIABLE run_result COMMAND_ERROR_IS_FATAL ANY)

execute_process(
  COMMAND
    "@CMAKE_COMMAND@" -S "@CMAKE_CURRENT_SOURCE_DIR@/install/sdk_consumer" -B
    "${sdk_consumer_build}" "-DCMAKE_PREFIX_PATH=${install_prefix}"
    "-DCMAKE_CXX_COMPILER=@CMAKE_CXX_COMPILER@"
  RESULT_VARIABLE sdk_configure_result COMMAND_ERROR_IS_FATAL ANY)

execute_process(COMMAND "@CMAKE_COMMAND@" --build "${sdk_consumer_build}"
                RESULT_VARIABLE sdk_build_result COMMAND_ERROR_IS_FATAL ANY)

execute_process(COMMAND "${sdk_consumer_build}/cxxlens-sdk-consumer"
                RESULT_VARIABLE sdk_run_result COMMAND_ERROR_IS_FATAL ANY)
