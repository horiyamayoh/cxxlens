set(test_root "@CMAKE_CURRENT_BINARY_DIR@/install-consumer")
set(install_prefix "${test_root}/prefix")
set(consumer_build "${test_root}/build")

file(REMOVE_RECURSE "${test_root}")

execute_process(
  COMMAND "@CMAKE_COMMAND@" --install "@CMAKE_BINARY_DIR@" --prefix
          "${install_prefix}" RESULT_VARIABLE install_result
                                              COMMAND_ERROR_IS_FATAL ANY)

foreach(
  required IN
  ITEMS
    "${install_prefix}/include/cxxlens/cxxlens.hpp"
    "${install_prefix}/include/cxxlens/explain.hpp"
    "${install_prefix}/include/cxxlens/search.hpp"
    "${install_prefix}/include/cxxlens/testing.hpp"
    "${install_prefix}/include/cxxlens/workspace.hpp"
    "${install_prefix}/include/cxxlens/facts.hpp"
    "${install_prefix}/include/cxxlens/interop/clang.hpp"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_public_api_contract.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_m0_completion.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_m1_completion.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_m1_completion.schema.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_m1_acceptance_report.schema.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_m2_completion.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_m2_completion.schema.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_m2_acceptance_report.schema.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_analysis_scope.schema.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_workspace_context.schema.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_fact.schema.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_frontend_batch.schema.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_observation.schema.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_search_report.schema.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_explanation.schema.yaml"
    "${install_prefix}/share/cxxlens/schemas/cxxlens_agent_task_card.schema.yaml"
    "${install_prefix}/share/doc/cxxlens/examples/m2-flagship/main.cpp"
    "${install_prefix}/share/doc/cxxlens/README.md"
    "${install_prefix}/share/doc/cxxlens/SECURITY.md")
  if(NOT EXISTS "${required}")
    message(FATAL_ERROR "installed M0 artifact is missing: ${required}")
  endif()
endforeach()

execute_process(
  COMMAND
    "@CMAKE_COMMAND@" -S "@CMAKE_CURRENT_SOURCE_DIR@/install/consumer" -B
    "${consumer_build}" "-DCMAKE_PREFIX_PATH=${install_prefix}"
    "-DCMAKE_CXX_COMPILER=@CMAKE_CXX_COMPILER@" "-DLLVM_DIR=@LLVM_DIR@"
    "-DClang_DIR=@Clang_DIR@"
  RESULT_VARIABLE configure_result COMMAND_ERROR_IS_FATAL ANY)

execute_process(COMMAND "@CMAKE_COMMAND@" --build "${consumer_build}"
                RESULT_VARIABLE build_result COMMAND_ERROR_IS_FATAL ANY)

execute_process(COMMAND "${consumer_build}/cxxlens-consumer"
                RESULT_VARIABLE run_result COMMAND_ERROR_IS_FATAL ANY)
